# EnvironmentFile for iterm2-push-relay.service. Copy to
# /etc/iterm2-push-relay.env, fill in, and `chmod 600` (it holds identifiers,
# though the signing key itself is a systemd credential, not here).

# --- Listener (loopback; the reverse proxy terminates TLS in front) ---
PUSH_HOST=127.0.0.1
PUSH_PORT=8790

# SQLite state file. With StateDirectory=iterm2-push-relay in the unit, systemd
# owns /var/lib/iterm2-push-relay for the DynamicUser.
PUSH_DB=/var/lib/iterm2-push-relay/push.db

# --- APNs identity (from developer.apple.com) ---
# Team ID (Membership) and the 10-char Key ID of the APNs auth key.
APNS_TEAM_ID=XXXXXXXXXX
APNS_KEY_ID=YYYYYYYYYY
# The app's bundle id (the apns-topic header).
APNS_TOPIC=com.googlecode.iterm2.companion

# The .p8 signing key is provided by the unit's LoadCredential= (preferred), so
# nothing to set here. If you would rather inline it instead of using a
# credential, drop the LoadCredential/APNS_P8_FILE lines from the unit and set a
# path here instead:
#   APNS_P8_FILE=/etc/iterm2-push-relay/apns.p8

# --- Registration record self-expiry (seconds). Default 90 days; min 60. ---
REGISTRATION_TTL_SECONDS=7776000

# --- Optional /register abuse cap by client IP (needs the proxy to forward
#     CF-Connecting-IP). Unset = unthrottled, like a CF deploy without the
#     rate-limit binding. ---
# PUSH_REGISTER_LIMIT=10
# PUSH_REGISTER_WINDOW_SECONDS=60
