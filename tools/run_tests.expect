#!/usr/bin/expect -f

if {$argc < 1} {
    puts "Usage: run_tests.expect <test-name>"
    puts "Example: run_tests.expect ModernTests/iTermScriptFunctionCallTest/testSignature"
    exit 1
}

set only_testing_flags {}
foreach test_name $argv {
    lappend only_testing_flags -only-testing:$test_name
}
set timeout -1

if {[info exists env(SIGNED)] && $env(SIGNED) eq "1"} {
    set signing_flags {}
} else {
    set signing_flags {CODE_SIGN_IDENTITY= CODE_SIGNING_REQUIRED=NO CODE_SIGNING_ALLOWED=NO}
}

# Defensively clear the AI live harness config file unless our parent
# tells us not to. The file is meaningful only during run_ai_live.sh;
# for plain ModernTests it's stale state (left over from a SIGKILL'd
# previous run, etc.) that would cause AILiveHarness to think we want
# a live-API run. run_ai_live.sh exports ITERM2_AI_LIVE_KEEP_CONFIG=1
# before invoking this script so its freshly-written config survives.
if {!([info exists env(ITERM2_AI_LIVE_KEEP_CONFIG)] && $env(ITERM2_AI_LIVE_KEEP_CONFIG) eq "1")} {
    if {[info exists env(TMPDIR)]} {
        set tmpdir $env(TMPDIR)
    } else {
        set tmpdir /tmp
    }
    file delete -force [file join $tmpdir iterm2-ai-live.json]
}

proc kill_tree {pid} {
    catch {
        set children [exec pgrep -P $pid]
        foreach child [split $children "\n"] {
            set child [string trim $child]
            if {$child ne ""} {
                kill_tree $child
            }
        }
    }
    catch {exec kill -9 $pid}
}

spawn xcodebuild test -project iTerm2.xcodeproj -scheme ModernTests {*}$only_testing_flags -parallel-testing-enabled NO {*}$signing_flags
set spawned_pid [exp_pid]

proc cleanup_and_exit {code} {
    global spawned_pid
    kill_tree $spawned_pid
    exit $code
}

trap {
    send_user "\n\n*** Interrupted, cleaning up ***\n\n"
    cleanup_and_exit 1
} {SIGINT SIGTERM}

expect {
    "Program crashed" {
        send_user "\n\n*** Detected interactive debug prompt, killing process ***\n\n"
        wait
        cleanup_and_exit 1
    }
    eof {
        catch wait result
        set code [lindex $result 3]
        if {$code != 0} {
            kill_tree $spawned_pid
        }
        exit $code
    }
}
